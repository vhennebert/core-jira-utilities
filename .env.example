JIRA_URL=https://your-instance.atlassian.net
JIRA_USERNAME=you@example.com

# Option 1 (recommended): path to a GPG-encrypted Personal Access Token
JIRA_TOKEN_PATH=~/.local/share/jira/pat.gpg

# Option 2: plain-text Personal Access Token (JIRA_TOKEN_PATH takes precedence if both are set)
# JIRA_TOKEN=your-personal-access-token
